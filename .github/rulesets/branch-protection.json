{
  "required_status_checks": {
    "strict": true,
                                       // Ensures branch is always up-to-date before merging (prevents outdated code merge
    "contexts": [
      "Lint",
      "Unit Tests (Node 20)",
      "All Checks Passed"
    ]                                  // These CI checks must pass before merging PR
  },
  "enforce_admins": true,              // Even admins must follow all rules
  "required_pull_request_reviews": {
    "required_approving_review_count": 1,       // # At least 1 approval required before merge
    "dismiss_stale_reviews": true,              // If new commits are pushed, previous approvals are dismissed
    "require_code_owner_reviews": false         // Code owner review not mandatory (can be enabled in enterprise)
  },
  "restrictions": null,                       // No specific user/team restrictions (can be added for tighter control)
  "allow_force_pushes": false,                // Prevent force push (protects commit history)
  "allow_deletions": false,                   // Prevent branch deletion (protects main branch)
  "required_linear_history": true,            // Enforces clean history (no merge commits, only rebase/squash)
  "required_conversation_resolution": true    // All PR comments must be resolved before merging
}
